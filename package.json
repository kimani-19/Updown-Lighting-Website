{
  "name": "up-down-lighting",
  "version": "1.0.0",
  "description": "Christmas lights installation service website for Bayport, Minnesota",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm install && npm run build"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^6.9.7",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "christmas",
    "lights",
    "installation",
    "bayport",
    "minnesota"
  ],
  "author": "Up-Down-Lighting",
  "license": "MIT"
}
